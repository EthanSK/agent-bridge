<?xml version="1.0" encoding="UTF-8"?>
<!--
  LaunchAgent template for the agent-bridge alexa-bridge receiver.

  This keeps the Alexa skill HTTP receiver running on the Mini and brings it
  back automatically after a crash or reboot, so the Alexa endpoint stays
  reachable (behind the public Funnel/tunnel) without manual restarts.

  Placeholders are filled in by install.sh:
    __NODE_BIN__      → absolute path to node (e.g. /opt/homebrew/bin/node)
    __SERVER_JS__     → absolute path to src/server.mjs in the checked-out repo
    __WORKDIR__       → the extension dir (working directory)
    __PORT__          → the port the receiver listens on (ALEXA_BRIDGE_PORT)
    __SECRET__        → optional shared secret (ALEXA_BRIDGE_SECRET; empty = off)
    __LOG_DIR__       → where stdout/stderr logs go

  KeepAlive + RunAtLoad = always-on supervisor. The receiver is stateless
  (no commissioning to preserve), so a restart just re-binds the port.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ethansk.agent-bridge-alexa-bridge</string>

    <key>ProgramArguments</key>
    <array>
        <string>__NODE_BIN__</string>
        <string>__SERVER_JS__</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__WORKDIR__</string>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- Port the receiver binds (the tunnel forwards public HTTPS → here). -->
        <key>ALEXA_BRIDGE_PORT</key>
        <string>__PORT__</string>
        <!-- Optional shared secret. Empty string = no secret check. When set,
             the Alexa endpoint URL must carry ?secret=<value>. -->
        <key>ALEXA_BRIDGE_SECRET</key>
        <string>__SECRET__</string>
        <!-- Ensure node + any spawned tooling can find Homebrew binaries. -->
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- Start at login and keep it alive: respawn on crash, on reboot. -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- A network listener is fine as a standard Aqua user agent. -->
    <key>ProcessType</key>
    <string>Interactive</string>

    <key>StandardOutPath</key>
    <string>__LOG_DIR__/alexa-bridge.out.log</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/alexa-bridge.err.log</string>
</dict>
</plist>
